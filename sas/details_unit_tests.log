3950  /*** 4. Full-join oracle vs ours, diff every count column, flag mismatches. ***/


3951  proc sql;
3952      create table compare as
3953      select
3954          coalesce(o.UnitId, w.UnitId) as UnitId,
3955          coalesce(o.Dept, '') as Dept,
3956          coalesce(o.Scope, w.Scope) as Scope,
3957          coalesce(o.Unit_Scholar_ID_c, w.Unit_Scholar_ID_c) as Unit_Scholar_ID,
3958          coalesce(o.Collab_Scholar_ID_c, w.Collab_Scholar_ID_c) as Collab_Scholar_ID,
3959          coalesce(o.Co_Authored_Articles,0) as oracle_articles,
3959! coalesce(w.Co_Authored_Articles,0) as our_articles,
3960          coalesce(o.Co_Authored_Books,0) as oracle_books, coalesce(w.Co_Authored_Books,0)
3960! as our_books,
3961          coalesce(o.Co_Authored_Chapters,0) as oracle_chapters,
3961! coalesce(w.Co_Authored_Chapters,0) as our_chapters,
3962          coalesce(o.Co_Authored_ConfProc,0) as oracle_confproc,
3962! coalesce(w.Co_Authored_ConfProc,0) as our_confproc,
3963          coalesce(o.Co_Authored_Grants,0) as oracle_grants,
3963! coalesce(w.Co_Authored_Grants,0) as our_grants,
3964          coalesce(o.Co_Authored_Patents,0) as oracle_patents,
3964! coalesce(w.Co_Authored_Patents,0) as our_patents,
3965          coalesce(o.Co_Authored_Trials,0) as oracle_trials,
3965! coalesce(w.Co_Authored_Trials,0) as our_trials,
3966          (missing(o.UnitId)) as missing_in_oracle,
3967          (missing(w.UnitId)) as missing_in_ours
3968      from oracle_pairs o
3969      full join our_pairs w
3970          on o.UnitId = w.UnitId and o.Scope = w.Scope
3971          and o.Unit_Scholar_ID_c = w.Unit_Scholar_ID_c and o.Collab_Scholar_ID_c =
3971! w.Collab_Scholar_ID_c
3972      ;
