102  /*** 2. Import every folder's within_unit.csv + across_units.csv, tag UnitId/Scope/
103     dept label, and stack into one oracle_pairs dataset.
104  
105     GETNAMES=NO + DATAROW=2 so SAS never tries to turn the header row into
106     variable names at all (sidesteps the 32-char limit entirely) - columns
107     come in as VAR1, VAR2, ... in file order, which is verified identical
108     across all 36 folders:
109       within_unit.csv:  1 Unit, 2 Unit Scholar, 3 Unit Scholar ID,
110                          4 Collab Scholar, 5 Collab Scholar ID,
111                          6 Articles, 7 Books, 8 Chapters, 9 ConfProc,
112                          10 Grants, 11 Patents, 12 Trials
113       across_units.csv: 1 Unit, 2 Unit Scholar, 3 Unit Scholar ID,
114                          4 Collab Unit, 5 Collab Scholar, 6 Collab Scholar ID,
115                          7 Articles, 8 Books, 9 Chapters, 10 ConfProc,
116                          11 Grants, 12 Patents, 13 Trials
117  ***/
118  %macro import_oracle(folder=, unitid=);
119      proc import datafile="&oracleloc.\&folder.\within_unit.csv"
120          out=_w replace dbms=csv; guessingrows=100000; getnames=no; datarow=2;
121      run;
122      data _w2;
123          length UnitId $10 Scope $20 Dept $60;
124          set _w(rename=(
125              VAR3=Unit_Scholar_ID   VAR5=Collab_Scholar_ID
126              VAR6=Co_Authored_Articles VAR7=Co_Authored_Books VAR8=Co_Authored_Chapters
127              VAR9=Co_Authored_ConfProc VAR10=Co_Authored_Grants
128              VAR11=Co_Authored_Patents VAR12=Co_Authored_Trials
129          ));
130          UnitId = "&unitid.";
131          Dept = "&folder.";
132          Scope = "Within Unit";
133          Unit_Scholar_ID_c  = cats(Unit_Scholar_ID);
134          Collab_Scholar_ID_c = cats(Collab_Scholar_ID);
135          keep UnitId Dept Scope Unit_Scholar_ID_c Collab_Scholar_ID_c
136              Co_Authored_Articles Co_Authored_Books Co_Authored_Chapters
137              Co_Authored_ConfProc Co_Authored_Grants
138              Co_Authored_Patents Co_Authored_Trials;
139      run;
140  
141      proc import datafile="&oracleloc.\&folder.\across_units.csv"
142          out=_a replace dbms=csv; guessingrows=100000; getnames=no; datarow=2;
143      run;
144      data _a2;
145          length UnitId $10 Scope $20 Dept $60;
146          set _a(rename=(
147              VAR3=Unit_Scholar_ID   VAR6=Collab_Scholar_ID
148              VAR7=Co_Authored_Articles VAR8=Co_Authored_Books VAR9=Co_Authored_Chapters
149              VAR10=Co_Authored_ConfProc VAR11=Co_Authored_Grants
150              VAR12=Co_Authored_Patents VAR13=Co_Authored_Trials
151          ));
152          UnitId = "&unitid.";
153          Dept = "&folder.";
154          Scope = "Across Units";
155          Unit_Scholar_ID_c  = cats(Unit_Scholar_ID);
156          Collab_Scholar_ID_c = cats(Collab_Scholar_ID);
157          keep UnitId Dept Scope Unit_Scholar_ID_c Collab_Scholar_ID_c
158              Co_Authored_Articles Co_Authored_Books Co_Authored_Chapters
159              Co_Authored_ConfProc Co_Authored_Grants
160              Co_Authored_Patents Co_Authored_Trials;
161      run;
162  
163      proc append base=oracle_pairs data=_w2 force; run;
164      proc append base=oracle_pairs data=_a2 force; run;
165  %mend;
