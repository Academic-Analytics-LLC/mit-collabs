4120  /**********************************************************************************
4121   6. BULK INSTITUTION-WIDE CROSS-CHECK (the two full-census downloads)
4122     collaborations_department_view.csv / collaborations_program_view.csv are
4123     FULL-CENSUS, WORK-GRAIN, ordered-pair (both directions), MIT-internal-only,
4124     Article + Conference Proceeding only. That grain matches details_base.csv
4125     almost exactly (no collapsing needed beyond the UnitType filter + explosion
4126     dedupe), so this is a stronger check than the per-department sampled files:
4127     every internal article/confproc collaboration at MIT, not just 36 anchors.
4128  
4129     department_view -> compare against UnitType='Department' on BOTH sides.
4130     program_view    -> compare against UnitType='Program' on BOTH sides.
4131  **********************************************************************************/
4132  %let bulkloc = &oracleloc.\_bulk_institution_wide;
4133  *Article/ConfProc product window (must match the &fouryear. window in the extract -
4134   the bulk downloads are NOT pre-windowed, they're a live/full-history pull, so without
4135   this filter the oracle side includes decades of pre-window articles the extract
4136   correctly excludes, making the comparison look like a massive false mismatch;
4137  %let yr_lo = 2021;
4138  %let yr_hi = 2024;
4139  
4140  %macro bulk_check(file=, unitkind=, label=);
4141  
4142      proc import datafile="&bulkloc.\&file."
4143          out=_bulk replace dbms=csv; guessingrows=100000; getnames=yes;
4144      run;
4145  
4146      data bulk_&label.;
4147          set _bulk;
4148          where pubyear between &yr_lo. and &yr_hi.;
4149          length CollaborationType $25;
4150          if isconfproc = 1 then CollaborationType = 'Conference Proceeding';
4151          else CollaborationType = 'Article';
4152          doi_c = cats(doi);
4153          AAUID_c = cats(AAUID);
4154          unitid_c = cats(unitid);
4155          collaboratorpersonid_c = cats(collaboratorpersonid);
4156          collaboratorunitid_c = cats(collaboratorunitid);
4157      run;
4158  
4159      proc sql;
4160          create table oracle_bulk_&label. as
4161          select distinct doi_c, AAUID_c, unitid_c, collaboratorpersonid_c,
4161! collaboratorunitid_c, CollaborationType
4162          from bulk_&label.;
4163      quit;
4164  
4165      *our side: both focal AND collaborator UnitType must match the requested unitkind,
4166       internal-only, Article/ConfProc only, then dedupe the explosion away;
4167      proc sql;
4168          create table our_bulk_&label. as
4169          select distinct
4170              cats(Collab_ID) as doi_c,
4171              cats(PersonId) as AAUID_c,
4172              cats(UnitId) as unitid_c,
4173              cats(Collab_PersonID) as collaboratorpersonid_c,
4174              cats(Collab_UnitId) as collaboratorunitid_c,
4175              CollaborationType
4176          from details
4177          where UnitType = "&unitkind." and Collab_UnitType = "&unitkind."
4178              and Collab_Dir = 'Internal'
4179              and CollaborationType in ('Article','Conference Proceeding')
4180          ;
4181      quit;
4182  
4183      proc sql;
4184          create table bulk_compare_&label. as
4185          select
4186              coalesce(o.doi_c, w.doi_c) as doi,
4187              coalesce(o.AAUID_c, w.AAUID_c) as AAUID,
4188              coalesce(o.unitid_c, w.unitid_c) as unitid,
4189              coalesce(o.collaboratorpersonid_c, w.collaboratorpersonid_c) as
4189! collaboratorpersonid,
4190              coalesce(o.collaboratorunitid_c, w.collaboratorunitid_c) as
4190! collaboratorunitid,
4191              coalesce(o.CollaborationType, w.CollaborationType) as CollaborationType,
4192              (missing(o.doi_c)) as missing_in_oracle,
4193              (missing(w.doi_c)) as missing_in_ours
4194          from oracle_bulk_&label. o
4195          full join our_bulk_&label. w
4196              on o.doi_c = w.doi_c and o.AAUID_c = w.AAUID_c and o.unitid_c = w.unitid_c
4197              and o.collaboratorpersonid_c = w.collaboratorpersonid_c and
4197! o.collaboratorunitid_c = w.collaboratorunitid_c
4198          ;
4199      quit;
4200  
4201      proc sql;
4202          select
4203              (select count(*) from oracle_bulk_&label.) as oracle_rows,
4204              (select count(*) from our_bulk_&label.) as our_rows,
4205              sum(missing_in_oracle) as extra_in_ours,
4206              sum(missing_in_ours) as missing_from_ours,
4207              count(*) - sum(missing_in_oracle) - sum(missing_in_ours) as matched
4208          from bulk_compare_&label.
4209          ;
4210      quit;
4211  
4212      proc export data=bulk_compare_&label.(where=(missing_in_oracle=1 or
4212! missing_in_ours=1))
4213          outfile="&outputloc.\bulk_mismatches_&label..csv" replace; run;
4214  
4215  %mend;
4216  
4217  title "Bulk cross-check: Department view (full MIT census, Article+ConfProc,
4217! internal-only)";
4218  %bulk_check(file=collaborations_department_view.csv, unitkind=Department, label=dept);



